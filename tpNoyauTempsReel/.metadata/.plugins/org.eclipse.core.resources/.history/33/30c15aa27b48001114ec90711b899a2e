int fonction(int argc, char ** argv)
{
	printf("Je suis une fonction\r\n");

	printf("argc = %d\r\n", argc);

	for (int i = 0 ; i < argc ; i++)
	{
		printf("argv[%d] = %s\r\n", i, argv[i]);
	}

	return 0;
}

int addition(int argc, char ** argv)
{
	if (argc == 3)	// Deux arguments + le nom de la fonction
	{
		int a = atoi(argv[1]);	// atoi = ASCII to Integer
		int b = atoi(argv[2]);

		printf("%d + %d = %d\r\n", a, b, a+b);

		return 0;
	}
	else
	{
		printf("Usage : %s <arg1> <arg2>\r\n", argv[0]);
		return -1;
	}
}

void task_shell(void * unused)
{
	shell_init();
	shell_add('f', *fonction, "Une fonction");
	shell_add('a', *addition, "Addition");
	shell_add('l', led, "Commande LED");
	shell_add('s', spam, "Spam message");
	shell_run();

	// shell_run = boucle infinie, on ne sort pas de la tache
	// Rappel : il est interdit de sortir d'une tache!
}

int led(int argc, char **argv)
{
	uint32_t period;

	if (argc != 2)
	{
		printf("Usage : %s <periode_ms>\r\n", argv[0]);
		return -1;
	}

	period = (uint32_t)atoi(argv[1]);

	if (xQueueOverwrite(ledQueue, &period) == pdPASS)
	{
		printf("Nouvelle periode LED = %lu ms\r\n", period);
		return 0;
	}

	printf("Erreur envoi ledQueue\r\n");
	return -1;
}

void task_led(void *unused)
{
	uint32_t newPeriod;

	for (;;)
	{
		if (xQueueReceive(ledQueue, &newPeriod, 0) == pdPASS)
		{
			ledPeriod = newPeriod;
		}

		if (ledPeriod == 0)
		{
			HAL_GPIO_WritePin(GPIOI, GPIO_led_Pin, GPIO_PIN_RESET);
			vTaskDelay(pdMS_TO_TICKS(20));
		}
		else
		{
			HAL_GPIO_TogglePin(GPIOI, GPIO_led_Pin
					);
			vTaskDelay(pdMS_TO_TICKS(ledPeriod));
		}
	}
}

int spam(int argc, char **argv)
{
	SpamMessage_t msg;

	if (argc != 3)
	{
		printf("Usage : %s <message> <nb>\r\n", argv[0]);
		return -1;
	}


	strncpy(msg.message, argv[1], sizeof(msg.message) - 1);
	msg.message[sizeof(msg.message) - 1] = '\0';

	// Convertir le nombre
	msg.count = (uint32_t)atoi(argv[2]);

	// Envoi dans la queue (bloquant pour éviter la perte)
	if (xQueueSend(spamQueue, &msg, portMAX_DELAY) == pdPASS)
	{
		printf("Spam envoye\r\n");
		return 0;
	}

	printf("Erreur envoi spamQueue\r\n");
	return -1;
}

void task_spam(void *unused)
{
	SpamMessage_t msg;

	for (;;)
	{
		if (xQueueReceive(spamQueue, &msg, portMAX_DELAY) == pdPASS)
		{
			for (uint32_t i = 0; i < msg.count; i++)
			{
				printf("%s\r\n", msg.message);
				printf("\r\n");
				vTaskDelay(pdMS_TO_TICKS(100));
			}
		}
	}
}
void task_dummy(void *unused)
{
    for (;;)
    {
        vTaskDelay(pdMS_TO_TICKS(1000));
